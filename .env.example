# ============================================================
# perception-mcp-server configuration
# ============================================================
#
# Copy this file to .env and edit values for your deployment.
# Anything left commented uses the default in main.py.

# --- Rosbridge connection ---------------------------------------------------
ROSBRIDGE_IP=127.0.0.1
ROSBRIDGE_PORT=9090

# --- SAM3 segmentation backend (optional) -----------------------------------
# Health-checked at startup so a missing segmentation server fails loud.
# Leave unset to skip the check (segment_objects will then time out silently
# if the backend is actually down).
# SAM3_REMOTE_URL=http://your-sam3-server:8001
