# Vision backend: "openai" (default, for Qwen3-VL) or "anthropic" (Claude)
VISION_BACKEND=openai

# For OpenAI-compatible backend (ZHAW Qwen3-VL)
VISION_BASE_URL=http://172.20.1.1:8000/v1
VISION_API_KEY=dummy
VISION_MODEL=QuantTrio/Qwen3-VL-30B-A3B-Instruct-AWQ

# For Anthropic backend (Claude)
# VISION_BACKEND=anthropic
# VISION_API_KEY=sk-ant-...
# VISION_MODEL=claude-sonnet-4-20250514

# Rosbridge connection (defaults shown)
ROSBRIDGE_IP=127.0.0.1
ROSBRIDGE_PORT=9090

# Camera topics (defaults for Summit XL)
PERCEPTION_RGB_TOPIC=/front_rgbd_camera/color/image_raw/compressed
PERCEPTION_DEPTH_TOPIC=/front_rgbd_camera/depth/image_raw
PERCEPTION_CAMERA_INFO_TOPIC=/front_rgbd_camera/depth/camera_info
