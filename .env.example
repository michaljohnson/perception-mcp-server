# ============================================================
# perception-mcp-server configuration
# ============================================================
#
# Copy this file to .env and edit values for your deployment.
# Anything left commented uses the default in main.py.

# --- Vision backend ---------------------------------------------------------
# "anthropic" — Anthropic-API-compatible vision models (Claude family)
# "openai"    — any OpenAI-compatible endpoint (vLLM, Ollama, hosted OpenAI...)
VISION_BACKEND=openai

# API key for the chosen provider. Provider-agnostic name; some self-hosted
# OpenAI-compatible endpoints don't require auth (any non-empty value works).
VISION_API_KEY=dummy

# Model id, as recognised by the chosen backend.
# Examples:
#   anthropic: claude-sonnet-4-20250514, claude-opus-4-6
#   openai:    gpt-4o-mini, llava, QuantTrio/Qwen3-VL-30B-A3B-Instruct-AWQ
VISION_MODEL=

# Base URL for OpenAI-compatible endpoints. Ignored when VISION_BACKEND=anthropic.
VISION_BASE_URL=http://127.0.0.1:8000/v1

# --- Rosbridge connection ---------------------------------------------------
ROSBRIDGE_IP=127.0.0.1
ROSBRIDGE_PORT=9090

# --- SAM3 segmentation backend (optional) -----------------------------------
# Health-checked at startup so a missing segmentation server fails loud.
# Leave unset to skip the check (segment_objects will then time out silently
# if the backend is actually down).
# SAM3_REMOTE_URL=http://your-sam3-server:8001
